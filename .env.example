# Quant Platform environment variables
# Copy this file to .env and fill in real local values.
# Never commit .env or production credentials.

# Flask session signing key. Use a long random value in production.
FLASK_SECRET_KEY=change-this-to-a-long-random-value

# Initial users created on first startup.
ADMIN_PASSWORD=change-this-admin-password
USER_PASSWORD=change-this-user-password

# Invite code required during registration.
INVITE_CODE=change-this-invite-code

# Crawler authentication.
CRAWLER_URL=
CRAWLER_USER=
CRAWLER_PASS=

# Email notifications.
SMTP_USER=
SMTP_PASS=
SMTP_HOST=smtp.example.com
SMTP_PORT=465
NOTIFY_EMAIL=
