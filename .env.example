# ── 量化分析系统 环境变量 ──
# 复制此文件为 .env 并填入真实值

# Web 密钥（用于 session 加密，务必修改）
FLASK_SECRET_KEY=your-secret-key-change-me

# 管理员初始密码（首次部署时创建账号用）
ADMIN_PASSWORD=请修改此密码
USER_PASSWORD=请修改此密码

# 邀请码（用户注册时需要）
INVITE_CODE=请修改此邀请码

# 爬虫目标网站地址及认证
CRAWLER_URL=
CRAWLER_USER=
CRAWLER_PASS=

# 邮件通知（用于发送验证码和流水线报告）
SMTP_USER=
SMTP_PASS=
SMTP_HOST=
SMTP_PORT=465
NOTIFY_EMAIL=
